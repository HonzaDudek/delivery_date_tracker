{% comment %}
  Estimated Delivery Date — Theme App Extension Block
  Displays estimated delivery date range on product pages.
{% endcomment %}

<div
  id="edd-delivery-estimate"
  class="edd-container"
  data-shop="{{ shop.permanent_domain }}"
  data-country="{{ localization.country.iso_code }}"
  data-product-id="{{ product.id }}"
  data-heading="{{ block.settings.heading }}"
  data-show-carrier="{{ block.settings.show_carrier }}"
  data-date-format="{{ block.settings.date_format }}"
>
  <div class="edd-loading">
    <span class="edd-spinner"></span>
    <span>{{ block.settings.heading | default: "Estimated Delivery" }}...</span>
  </div>
  <noscript>
    <p>Enable JavaScript to see estimated delivery dates.</p>
  </noscript>
</div>

<style>
  .edd-container {
    padding: 12px 0;
    font-family: inherit;
  }
  .edd-heading {
    font-weight: 600;
    margin-bottom: 4px;
    font-size: 0.875rem;
  }
  .edd-date {
    font-size: 1rem;
    font-weight: 700;
    color: var(--edd-color, #2c6e49);
  }
  .edd-carrier {
    font-size: 0.75rem;
    color: #666;
    margin-top: 2px;
  }
  .edd-loading {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #888;
    font-size: 0.875rem;
  }
  .edd-spinner {
    width: 14px;
    height: 14px;
    border: 2px solid #ddd;
    border-top-color: #333;
    border-radius: 50%;
    animation: edd-spin 0.6s linear infinite;
  }
  .edd-error {
    display: none;
    color: #888;
    font-size: 0.875rem;
  }
  @keyframes edd-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script src="{{ 'delivery-date.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Delivery Date Estimate",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Estimated Delivery"
    },
    {
      "type": "checkbox",
      "id": "show_carrier",
      "label": "Show carrier name",
      "default": true
    },
    {
      "type": "select",
      "id": "date_format",
      "label": "Date format",
      "default": "long",
      "options": [
        { "value": "long", "label": "Long (March 25, 2026)" },
        { "value": "short", "label": "Short (Mar 25)" },
        { "value": "numeric", "label": "Numeric (03/25/2026)" }
      ]
    }
  ]
}
{% endschema %}
