generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
}

model Shop {
  id             String         @id @default(cuid())
  shopifyDomain  String         @unique
  shopifyId      String         @unique
  plan           String         @default("free")
  processingDays Int            @default(1)
  cutoffTime     String         @default("14:00")
  timezone       String         @default("America/New_York")
  skipWeekends   Boolean        @default(true)
  installedAt    DateTime       @default(now())
  settings       String?
  shippingZones  ShippingZone[]
  excludedDates  ExcludedDate[]
  estimateLogs   EstimateLog[]
}

model ShippingZone {
  id             String @id @default(cuid())
  shopId         String
  shop           Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name           String
  countries      String
  regions        String @default("")
  carrier        String
  transitDaysMin Int
  transitDaysMax Int
}

model ExcludedDate {
  id        String  @id @default(cuid())
  shopId    String
  shop      Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  date      String
  reason    String?
  recurring Boolean @default(false)
}

model EstimateLog {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productId String?
  zone      String
  estimate  String
  createdAt DateTime @default(now())
}
